<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KargoX Lojistik</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-warning" asp-controller="Home" asp-action="Index">📦 KargoX</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Kargom Nerede?</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Istatistikler">Şube Raporları</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="Home" asp-action="TabloGoster">⚙️ Sistem Yönetimi</a>
                        </li>
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-success fw-bold px-3 shadow-sm" asp-controller="Home" asp-action="KargoEkle">+ Yeni Kargo Ekle</a>
                        </li>
                    </ul>
                    <span class="navbar-text text-light">
                        <em>Güvenli ve Hızlı Teslimat</em>
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4 flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - KargoX Lojistik Sistemi - Veritabanı Projesi
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>